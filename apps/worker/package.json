{
  "name": "@bushiri/worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "dev:local": "wrangler dev --local --port 8787",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "d1:migrate:local": "wrangler d1 migrations apply bushiri --local",
    "d1:migrate:remote": "wrangler d1 migrations apply bushiri --remote"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "wrangler": "^4.12.0"
  }
}
